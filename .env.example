# Rename this file to .env and fill in the values.

# --- Web Server ---
HOST=0.0.0.0
PORT=8000

# --- Admin Credentials (Basic Auth) ---
# Generate password hash with:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$CHANGE_THIS_TO_A_REAL_BCRYPT_HASH

# --- UDP Listener defaults (overridden via Settings UI) ---
UDP_LISTEN_IP=0.0.0.0
UDP_LISTEN_PORT=5005

# --- Database path ---
DATABASE_URL=data/mapper.db

# --- Logging ---
LOG_MAX_ENTRIES=1000
